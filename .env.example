# Google OAuth
CLIENT_SECRETS_FILE=client_secret_460743254593-m643fhnp83goi9ooata786l29lkvij4f.apps.googleusercontent.com.json
OAUTH_REDIRECT_URI=http://localhost:8000/auth/callback

# Supabase
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# OpenRouter (for audit + prompt generation)
OPENROUTER_API_KEY=sk-or-...

# Session signing key (any random string)
SESSION_SECRET=change-me-to-a-long-random-string

# Set to true while testing — write-back will log payloads instead of pushing to YouTube
DRY_RUN=true

# Required for OAuth over http://localhost in dev (do NOT set in prod)
OAUTHLIB_INSECURE_TRANSPORT=1
