# ──────────────────────────────────────────────────────────────────────────
# Midas environment template. Copy to `.env` and fill in the REQUIRED values.
# Every var below is read in app/config.py. Anything left out falls back to the
# default shown here, so you only NEED the four required secrets to boot.
# ──────────────────────────────────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────────────────────────────────
# Supabase (app raises at startup if these are missing).
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key      # legacy service_role JWT, starts with "eyJ"

# OpenRouter — all LLM calls (audit, prompt-gen, reflection).
OPENROUTER_API_KEY=sk-or-...

# Session signing key (defaults to an insecure dev value — set a real one).
SESSION_SECRET=change-me-to-a-long-random-string

# ── Google OAuth ──────────────────────────────────────────────────────────
CLIENT_SECRETS_FILE=client_secret_460743254593-m643fhnp83goi9ooata786l29lkvij4f.apps.googleusercontent.com.json
OAUTH_REDIRECT_URI=http://localhost:8000/auth/callback
# Required for OAuth over http://localhost in dev (do NOT set in prod).
OAUTHLIB_INSECURE_TRANSPORT=1

# ── Runtime mode ──────────────────────────────────────────────────────────
# true = write-back logs payloads instead of pushing to YouTube.
DRY_RUN=true

# ── LLM model selection (OpenRouter model ids) ────────────────────────────
AUDIT_MODEL=anthropic/claude-haiku-4.5
PROMPT_GEN_MODEL=google/gemini-2.0-flash-001
REFLECTION_MODEL=anthropic/claude-sonnet-4-6

# Set in docker-compose.yml (bgutil sidecar). Leave unset on the Mac to use the local node script.
# BGUTIL_POT_HTTP_BASE_URL=http://bgutil-provider:4416
SHORTS_CACHE_DIR=./shorts_cache

# ── YouTube quota / autopilot ─────────────────────────────────────────────
YT_DAILY_QUOTA=10000
YT_QUOTA_SAFETY_BUFFER=300
AUTOPILOT_TICK_SECONDS=120

# ── YouTube transcript proxy — needed when hosted on cloud IPs ─────────────
# Option A: Webshare rotating residential proxy (recommended).
#   Sign up at https://www.webshare.io, buy a "Residential" package.
#   Credentials: https://dashboard.webshare.io/proxy/settings
# WEBSHARE_PROXY_USERNAME=your-proxy-username
# WEBSHARE_PROXY_PASSWORD=your-proxy-password
#
# Option B: any HTTP/HTTPS/SOCKS proxy.
# YOUTUBE_PROXY_URL=http://user:pass@host:port

# ── Playlist automation ───────────────────────────────────────────────────
PLAYLIST_HITL=true              # false = execute changes directly (autopilot)
PLAYLIST_JOIN_HIGH=0.72         # cosine sim for direct add
PLAYLIST_JOIN_LOW=0.55          # haiku review band lower bound
PLAYLIST_LEAVE=0.60             # haiku-confirmed removal
PLAYLIST_MUTATION_CAP=20        # max add+remove per reconcile

# ── Playlist health scoring (recommend-only) ──────────────────────────────
MIN_PLAYLIST_STARTS=50
PLAYLIST_MEASUREMENT_WINDOW_DAYS=35
PLAYLIST_HEALTH_AGG_WEEKS=4
PLAYLIST_HEALTH_REMOVE_PCTL=5
PLAYLIST_HEALTH_REVIVE_PCTL=20

# ── Content-aware audit ───────────────────────────────────────────────────
TRANSCRIPT_MAX_CHARS=8000
KEYFRAME_MAX_FRAMES=4
KEYFRAMES_LOCAL_DIR=storage/keyframes
KEYFRAME_FFMPEG_TIMEOUT=30
